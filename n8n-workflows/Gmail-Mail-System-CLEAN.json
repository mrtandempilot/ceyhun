    {
      "parameters": {
        "jsCode": "// Combine inbox and sent\nconst inbox = $('Gmail All Inbox').all();\nconst sent = $('Gmail All Sent').all();\n\nconst processEmail = (email, type) => ({\n  id: email.json.id,\n  threadId: email.json.threadId,\n  type: type,\n  from: email.json.from?.value?.[0]?.address || email.json.from || '',\n  to: email.json.to?.value?.[0]?.address || email.json.to || '',\n  subject: email.json.subject || '(No Subject)',\n  snippet: email.json.snippet || '',\n  date: email.json.date,\n  isRead: !email.json.labelIds?.includes('UNREAD')\n});\n\nconst allEmails = [\n  ...inbox.map(e => processEmail(e, 'inbox')),\n  ...sent.map(e => processEmail(e, 'sent'))\n].sort((a, b) => new Date(b.date) - new Date(a.date));\n\nreturn [{\n  json: {\n    success: true,\n    inboxCount: inbox.length,\n    sentCount: sent.length,\n    totalCount: allEmails.length,\n    emails: allEmails,\n    fetchedAt: new Date().toISOString()\n  }\n}];"
      },
