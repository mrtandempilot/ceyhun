    },
    {
      "parameters": {
        "jsCode": "// Process inbox emails\nconst emails = $input.all();\n\nconst processedEmails = emails.map(item => {\n  const email = item.json;\n  return {\n    id: email.id,\n    threadId: email.threadId,\n    from: email.from?.value?.[0]?.address || email.from || 'Unknown',\n    fromName: email.from?.value?.[0]?.name || '',\n    to: email.to?.value?.[0]?.address || email.to || '',\n    subject: email.subject || '(No Subject)',\n    snippet: email.snippet || '',\n    date: email.date,\n    isRead: !email.labelIds?.includes('UNREAD'),\n    hasAttachment: email.labelIds?.includes('ATTACHMENT') || false,\n    labels: email.labelIds || [],\n    body: email.text || email.html || ''\n  };\n});\n\nreturn [{\n  json: {\n    success: true,\n    type: 'inbox',\n    count: processedEmails.length,\n    emails: processedEmails,\n    fetchedAt: new Date().toISOString()\n  }\n}];"
      },
